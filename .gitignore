# Runtime environments and caches
.venv/
**/.venv/
**/.pytest_cache/
**/.ruff_cache/
**/__pycache__/

# Video service working data
videos/incoming/*
videos/jobs/*
videos/exports/*
videos/tmp/*

!videos/incoming/.gitkeep
!videos/jobs/.gitkeep
!videos/exports/.gitkeep
!videos/tmp/.gitkeep
!videos/README.md

# Large media and generated transcript artifacts in the video workspace should stay local unless explicitly curated.
videos/**/*.mp4
videos/**/*.mov
videos/**/*.mkv
videos/**/*.avi
videos/**/*.webm
videos/**/*.mp3
videos/**/*.wav
videos/**/*.flac
videos/**/*.srt
videos/**/*.ass
videos/**/*.vtt
